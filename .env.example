CLIENT_ID=your_discord_application_client_id_here

# Database Configuration
DATABASE_URL=mysql://username:password@host:port/database_name

# Data Encryption Configuration (Generate secure keys!)
ENCRYPTION_KEY=generate_32_byte_hex_key_using_crypto_randomBytes
SEARCH_SALT=generate_16_byte_hex_salt_using_crypto_randomBytes

# Example generation commands:
# node -e "const crypto = require('crypto'); console.log('ENCRYPTION_KEY=' + crypto.randomBytes(32).toString('hex'));"
# node -e "const crypto = require('crypto'); console.log('SEARCH_SALT=' + crypto.randomBytes(16).toString('hex'));"
